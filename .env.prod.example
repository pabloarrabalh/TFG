# Production backend image built and pushed to ACR/Docker Hub
BACKEND_IMAGE=your-registry.azurecr.io/tfg-backend:latest

# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
BACKEND_PUBLIC_HOST=api.<your-vm-ip>.sslip.io
EXTRA_ALLOWED_HOSTS=api.<your-vm-ip>.sslip.io,your-custom-domain.com
EXTRA_CORS_ORIGINS=https://your-frontend.vercel.app

# Supabase
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_SSL=true

# Upstash Redis
REDIS_URL=rediss://default:<password>@<host>:<port>

# Meilisearch
MEILI_MASTER_KEY=replace-with-a-strong-shared-key
MEILISEARCH_API_KEY=replace-with-a-strong-shared-key

# Optional app secrets
API_FOOTBALL_KEY=
